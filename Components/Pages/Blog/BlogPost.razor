@page "/blog/{Slug}"
@inject IUtilityMenuApiClient Api
@inject NavigationManager Nav

@if (_loading)
{
    <LoadingSpinner />
}
else if (_post is null)
{
    <div class="container py-5 text-center">
        <h1>Post Not Found</h1>
        <p class="text-muted">The blog post you're looking for doesn't exist.</p>
        <a href="/blog" class="btn btn-outline-primary">Back to Blog</a>
    </div>
}
else
{
    <PageTitle>@(_post.MetaTitle ?? _post.Title) | UtilityMenu Blog</PageTitle>
    <HeadContent>
        <meta name="description" content="@(_post.MetaDescription ?? _post.Summary)" />
        <meta property="og:title" content="@(_post.MetaTitle ?? _post.Title)" />
        <meta property="og:description" content="@(_post.MetaDescription ?? _post.Summary)" />
        @if (!string.IsNullOrWhiteSpace(_post.CoverImageUrl))
        {
            <meta property="og:image" content="@_post.CoverImageUrl" />
        }
    </HeadContent>

    @if (!string.IsNullOrWhiteSpace(_post.CoverImageUrl))
    {
        <div style="height:320px; overflow:hidden; background:#f8f9fa;">
            <img src="@_post.CoverImageUrl" alt="@_post.Title" style="width:100%; height:100%; object-fit:cover;" />
        </div>
    }

    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <a href="/blog" class="text-decoration-none text-muted small mb-3 d-inline-block">
                    <i class="bi bi-arrow-left me-1"></i>Back to Blog
                </a>

                <div class="d-flex align-items-center gap-2 mb-3">
                    <span class="badge bg-primary-subtle text-primary">@(_post.CategoryName ?? "Blog")</span>
                    <small class="text-muted">@_post.PublishedAt?.ToString("MMMM d, yyyy")</small>
                </div>

                <h1 class="fw-bold mb-4">@_post.Title</h1>

                <MarkdownRenderer Content="@_post.Body" />
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;

    private BlogPostDto? _post;
    private bool _loading = true;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        var result = await Api.GetPostBySlugAsync(Slug);
        if (result.IsSuccess) _post = result.Value;
        _loading = false;
    }
}
