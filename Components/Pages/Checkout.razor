@page "/pricing/checkout"
@rendermode InteractiveServer
@attribute [Authorize]
@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.Options
@using UtilityMenuSite.Infrastructure.Configuration
@inject AuthenticationStateProvider AuthProvider
@inject UserManager<Data.Models.ApplicationUser> UserManager
@inject IStripeService StripeService
@inject IOptions<StripeSettings> StripeOptions
@inject NavigationManager Nav
@inject ILogger<Checkout> Logger

<PageTitle>Checkout — UtilityMenu</PageTitle>
<HeadContent>
    <meta name="description" content="Subscribe to UtilityMenu Pro and unlock all advanced modules." />
</HeadContent>

<div class="container py-6">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">

            @if (_loading)
            {
                <LoadingSpinner Message="Preparing your checkout..." />
            }
            else if (!string.IsNullOrWhiteSpace(_error))
            {
                <AlertBanner Message="@_error" Type="danger" />
                <div class="text-center mt-3">
                    <a href="/pricing" class="btn btn-outline-secondary">Back to Pricing</a>
                </div>
            }
            else
            {
                <!-- Order Summary -->
                <div class="text-center mb-4">
                    <h1 class="fw-bold fs-2">Complete Your Order</h1>
                    <p class="text-muted">You're one step away from unlocking UtilityMenu Pro.</p>
                </div>

                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-primary text-white fw-semibold">
                        <i class="bi bi-bag-check me-2"></i>Order Summary
                    </div>
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div>
                                <div class="fw-bold fs-5">UtilityMenu Pro</div>
                                <div class="text-muted small">@_billingDescription</div>
                            </div>
                            <div class="text-end">
                                <span class="fw-bold fs-4">@_displayPrice</span>
                                <div class="text-muted small">/@_period</div>
                            </div>
                        </div>

                        @if (_isAnnual)
                        {
                            <div class="alert alert-success py-2 mb-3 d-flex align-items-center gap-2">
                                <i class="bi bi-tag-fill"></i>
                                <span class="small">You save <strong>£15</strong> compared to monthly billing.</span>
                            </div>
                        }

                        <hr />

                        <ul class="list-unstyled mb-0 small text-muted">
                            <li class="mb-1"><i class="bi bi-check-lg text-success me-2"></i>All Pro modules unlocked immediately</li>
                            <li class="mb-1"><i class="bi bi-check-lg text-success me-2"></i>Up to 2 active machines</li>
                            <li class="mb-1"><i class="bi bi-check-lg text-success me-2"></i>Priority support</li>
                            <li class="mb-1"><i class="bi bi-check-lg text-success me-2"></i>Cancel any time</li>
                            @if (_isAnnual)
                            {
                                <li><i class="bi bi-check-lg text-success me-2"></i>25% saving vs monthly</li>
                            }
                        </ul>
                    </div>
                </div>

                <!-- Checkout Button -->
                <div class="d-grid gap-2">
                    <button class="btn btn-primary btn-lg fw-semibold" @onclick="ProceedToStripe" disabled="@_checkoutLoading">
                        @if (_checkoutLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>Redirecting to Stripe...</span>
                        }
                        else
                        {
                            <i class="bi bi-lock-fill me-2"></i>
                            <span>Pay securely with Stripe</span>
                        }
                    </button>
                    <a href="/pricing" class="btn btn-outline-secondary">Back to Pricing</a>
                </div>

                <p class="text-muted small text-center mt-3">
                    <i class="bi bi-shield-lock me-1"></i>
                    Payment is handled securely by Stripe. We never store your card details.
                </p>
            }

        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "plan")]
    public string? Plan { get; set; }

    private bool _loading = true;
    private bool _checkoutLoading;
    private bool _isAnnual;
    private string? _error;
    private string? _userEmail;

    private string _displayPrice => _isAnnual ? "£45" : "£5";
    private string _period => _isAnnual ? "year" : "month";
    private string _billingDescription => _isAnnual ? "Billed annually" : "Billed monthly";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isAnnual = string.Equals(Plan, "annual", StringComparison.OrdinalIgnoreCase);

        var prices = StripeOptions.Value.Prices;
        var priceId = _isAnnual ? prices.ProAnnual : prices.ProMonthly;

        if (string.IsNullOrWhiteSpace(priceId))
        {
            _error = "Checkout is not available right now. Please try again later or contact support.";
            _loading = false;
            StateHasChanged();
            return;
        }

        try
        {
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            var identityUser = await UserManager.GetUserAsync(authState.User);
            if (identityUser is null)
            {
                Nav.NavigateTo($"/account/login?returnUrl={Uri.EscapeDataString("/pricing/checkout?plan=" + (Plan ?? "monthly"))}");
                return;
            }
            _userEmail = identityUser.Email;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to resolve user on checkout page");
            _error = "Unable to load your account. Please refresh and try again.";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task ProceedToStripe()
    {
        if (string.IsNullOrWhiteSpace(_userEmail)) return;

        _checkoutLoading = true;
        StateHasChanged();

        try
        {
            var prices = StripeOptions.Value.Prices;
            var priceId = _isAnnual ? prices.ProAnnual : prices.ProMonthly;
            var planType = _isAnnual ? "annual" : "monthly";

            var result = await StripeService.CreateCheckoutSessionAsync(
                priceId, _userEmail, "subscription", planType);

            Nav.NavigateTo(result.CheckoutUrl, forceLoad: true);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to create checkout session for {Email}", _userEmail);
            _error = "Failed to start checkout. Please try again or contact support.";
            _checkoutLoading = false;
            StateHasChanged();
        }
    }
}
