@page "/Error"
@using Microsoft.AspNetCore.Diagnostics
@inject ILogger<Error> Logger

<PageTitle>Error — UtilityMenu</PageTitle>

<div class="container py-6 text-center">
    <div class="py-5">
        <i class="bi bi-exclamation-triangle-fill text-danger display-3 mb-4 d-block"></i>
        <h1 class="fw-bold">An error occurred</h1>
        <p class="text-muted lead">We're sorry — something went wrong on our end. Please try again or <a href="/contact">contact support</a>.</p>
        <a href="/" class="btn btn-primary mt-3">Return Home</a>
    </div>
</div>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    protected override void OnInitialized()
    {
        var feature = HttpContext?.Features.Get<IExceptionHandlerPathFeature>();
        if (feature?.Error is { } ex)
        {
            Logger.LogError(ex, "Unhandled exception on path {Path}", feature.Path);
        }
    }
}
