@page "/admin/users/{UserId:guid}"
@rendermode InteractiveServer
@layout AdminLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@inject IUtilityMenuApiClient Api
@inject ILogger<AdminUserDetail> Logger

<PageTitle>User Detail — Admin</PageTitle>

@if (_loading)
{
    <LoadingSpinner />
}
else if (_detail is null)
{
    <div class="mb-3">
        <a href="/admin" class="text-decoration-none text-muted small"><i class="bi bi-arrow-left me-1"></i>Back to Admin</a>
    </div>
    <AlertBanner Message="User not found." Type="danger" Dismissible="false" />
}
else
{
    <div class="mb-3">
        <a href="/admin" class="text-decoration-none text-muted small"><i class="bi bi-arrow-left me-1"></i>Back to Admin</a>
    </div>

    <h2 class="fw-bold mb-4">@(_detail.User.DisplayName ?? _detail.User.Email)</h2>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <AlertBanner Message="@_message" Type="@_messageType" />
    }

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-transparent border-0 fw-semibold">Account Details</div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-muted small">Email</dt>
                        <dd class="col-sm-8 small">@_detail.User.Email</dd>
                        <dt class="col-sm-4 text-muted small">Display Name</dt>
                        <dd class="col-sm-8 small">@(_detail.User.DisplayName ?? "—")</dd>
                        <dt class="col-sm-4 text-muted small">Organisation</dt>
                        <dd class="col-sm-8 small">@(_detail.User.Organisation ?? "—")</dd>
                        <dt class="col-sm-4 text-muted small">User ID</dt>
                        <dd class="col-sm-8 small text-muted" style="font-size:0.7rem;">@_detail.User.UserId</dd>
                        <dt class="col-sm-4 text-muted small">Registered</dt>
                        <dd class="col-sm-8 small">@_detail.User.CreatedAt.ToString("MMMM d, yyyy")</dd>
                        <dt class="col-sm-4 text-muted small">Status</dt>
                        <dd class="col-sm-8">
                            <span class="badge @(_detail.User.IsActive ? "bg-success" : "bg-danger")">
                                @(_detail.User.IsActive ? "Active" : "Inactive")
                            </span>
                        </dd>
                        @if (!string.IsNullOrEmpty(_detail.User.ApiToken))
                        {
                            <dt class="col-sm-4 text-muted small">API Token</dt>
                            <dd class="col-sm-8 small text-muted">@(_detail.User.ApiToken[..Math.Min(8, _detail.User.ApiToken.Length)])…</dd>
                        }
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-transparent border-0 fw-semibold">Licence</div>
                <div class="card-body">
                    @if (_detail.Licence is not null)
                    {
                        <dl class="row mb-3">
                            <dt class="col-sm-4 text-muted small">Key</dt>
                            <dd class="col-sm-8"><code class="small">@_detail.Licence.LicenceKey</code></dd>
                            <dt class="col-sm-4 text-muted small">Type</dt>
                            <dd class="col-sm-8 small">@_detail.Licence.LicenceType.ToUpperInvariant()</dd>
                            <dt class="col-sm-4 text-muted small">Status</dt>
                            <dd class="col-sm-8">
                                <span class="badge @(_detail.Licence.IsActive ? "bg-success" : "bg-danger")">
                                    @(_detail.Licence.IsActive ? "Active" : "Inactive")
                                </span>
                            </dd>
                            @if (_detail.Licence.ExpiresAt.HasValue)
                            {
                                <dt class="col-sm-4 text-muted small">Expires</dt>
                                <dd class="col-sm-8 small">@_detail.Licence.ExpiresAt.Value.ToString("MMM d, yyyy")</dd>
                            }
                        </dl>
                        @if (_detail.Licence.GrantedModules.Count > 0)
                        {
                            <small class="text-muted fw-semibold d-block mb-2">Modules</small>
                            <div class="d-flex flex-wrap gap-1 mb-2">
                                @foreach (var moduleName in _detail.Licence.GrantedModules)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle small">@moduleName</span>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted mb-0">No active licence.</p>
                    }
                </div>
            </div>
        </div>

        @if (_detail.Licence is not null)
        {
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-transparent border-0 fw-semibold">
                        <i class="bi bi-puzzle me-2 text-primary"></i>Manage Modules
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            @foreach (var module in _detail.AllModules)
                            {
                                var isGranted = _detail.Licence.GrantedModules.Contains(module.ModuleName);
                                <div class="col-sm-6 col-lg-4">
                                    <div class="d-flex align-items-center justify-content-between p-2 border rounded @(isGranted ? "border-success-subtle bg-success-subtle" : "bg-light")">
                                        <div>
                                            <div class="fw-semibold small">@(module.DisplayName ?? module.ModuleName)</div>
                                            <div class="text-muted" style="font-size:0.7rem;">@module.Tier</div>
                                        </div>
                                        @if (isGranted)
                                        {
                                            <button class="btn btn-outline-danger btn-sm" @onclick="() => RevokeModule(module.ModuleId)" title="Revoke">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-outline-success btn-sm" @onclick="() => GrantModule(module.ModuleId)" title="Grant">
                                                <i class="bi bi-plus-lg"></i>
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (_detail.Licence is not null && _detail.Licence.Machines.Count > 0)
        {
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-transparent border-0 fw-semibold">
                        Active Machines
                        <span class="badge bg-secondary ms-2">@_detail.Licence.Machines.Count / @_detail.Licence.MaxActivations</span>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-sm mb-0">
                                <thead class="table-light">
                                    <tr><th>Name</th><th>First Seen</th><th>Last Seen</th><th></th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var m in _detail.Licence.Machines)
                                    {
                                        <tr>
                                            <td>@(m.MachineName ?? "Unknown")</td>
                                            <td>@m.FirstSeenAt.ToString("MMM d, yyyy")</td>
                                            <td>@m.LastSeenAt.ToString("MMM d, yyyy")</td>
                                            <td>
                                                <button class="btn btn-outline-danger btn-sm" @onclick="() => DeactivateMachine(m.MachineId)">
                                                    Deactivate
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter] public Guid UserId { get; set; }

    private AdminUserDetailDto? _detail;
    private bool _loading = true;
    private string? _message;
    private string _messageType = "danger";

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _message = null;
        var result = await Api.GetAdminUserDetailAsync(UserId);
        if (result.IsSuccess) _detail = result.Value;
        else if (result.ErrorCode != "http_404")
        {
            Logger.LogWarning("Admin user detail load failed for {UserId}: {Code}", UserId, result.ErrorCode);
            _message = "Failed to load user details.";
        }
        _loading = false;
    }

    private async Task GrantModule(Guid moduleId)
    {
        if (_detail?.Licence is null) return;
        var result = await Api.GrantModuleAsync(_detail.Licence.LicenceId, new GrantModuleRequest(moduleId, null));
        await ApplyResultAndReload(result, "Module granted.");
    }

    private async Task RevokeModule(Guid moduleId)
    {
        if (_detail?.Licence is null) return;
        var result = await Api.RevokeModuleAsync(_detail.Licence.LicenceId, moduleId);
        await ApplyResultAndReload(result, "Module revoked.");
    }

    private async Task DeactivateMachine(Guid machineId)
    {
        var result = await Api.DeactivateMachineAsync(machineId);
        await ApplyResultAndReload(result, "Machine deactivated.");
    }

    private async Task ApplyResultAndReload(ApiResult result, string successMessage)
    {
        if (result.IsSuccess)
        {
            var refreshed = await Api.GetAdminUserDetailAsync(UserId);
            if (refreshed.IsSuccess) _detail = refreshed.Value;
            _message = successMessage;
            _messageType = "success";
        }
        else
        {
            _message = result.ErrorMessage ?? "Operation failed.";
            _messageType = "danger";
        }
        StateHasChanged();
    }
}
