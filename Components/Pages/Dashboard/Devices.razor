@page "/dashboard/devices"
@rendermode InteractiveServer
@layout DashboardLayout
@attribute [Authorize]
@using Microsoft.AspNetCore.Identity
@inject AuthenticationStateProvider AuthProvider
@inject UserManager<Data.Models.ApplicationUser> UserManager
@inject IUserService UserService
@inject ILicenceService LicenceService
@inject NavigationManager Nav
@inject ILogger<Devices> Logger

<PageTitle>Devices — UtilityMenu Dashboard</PageTitle>

@if (_loading)
{
    <LoadingSpinner Message="Loading devices..." />
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Devices</h2>
            <p class="text-muted mb-0">Machines with your UtilityMenu licence activated</p>
        </div>
        @if (_licence is not null)
        {
            <span class="badge bg-secondary fs-6">
                @_machines.Count / @_licence.MaxActivations used
            </span>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <AlertBanner Message="@_message" Type="@_messageType" />
    }

    @if (_licence is null)
    {
        <div class="card border-0 shadow-sm text-center py-5">
            <div class="card-body">
                <i class="bi bi-laptop text-muted" style="font-size:3rem;"></i>
                <h5 class="mt-3 fw-semibold">No licence found</h5>
                <p class="text-muted">You need an active licence before you can activate devices.</p>
                <a href="/pricing" class="btn btn-primary">
                    <i class="bi bi-arrow-up-circle me-2"></i>Upgrade to Pro
                </a>
            </div>
        </div>
    }
    else
    {
        <!-- Activation limit banner -->
        @if (_machines.Count >= _licence.MaxActivations)
        {
            <div class="alert alert-warning d-flex align-items-center gap-2 mb-4">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <div>
                    You've reached your activation limit of <strong>@_licence.MaxActivations devices</strong>.
                    Deactivate an existing device before activating a new one.
                </div>
            </div>
        }

        <!-- Device list -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent border-0 fw-semibold">
                <i class="bi bi-laptop me-2 text-primary"></i>Activated Machines
            </div>
            <div class="card-body p-0">
                @if (_machines.Any())
                {
                    <div class="list-group list-group-flush">
                        @foreach (var machine in _machines.OrderByDescending(m => m.LastSeenAt))
                        {
                            <div class="list-group-item d-flex align-items-center justify-content-between py-3 px-4">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="text-primary">
                                        <i class="bi bi-pc-display-horizontal fs-4"></i>
                                    </div>
                                    <div>
                                        <div class="fw-semibold">@(machine.MachineName ?? "Unknown Machine")</div>
                                        <div class="text-muted small">
                                            First activated: @machine.FirstSeenAt.ToString("MMM d, yyyy")
                                            &nbsp;·&nbsp;
                                            Last seen: @machine.LastSeenAt.ToString("MMM d, yyyy")
                                        </div>
                                        <div class="text-muted" style="font-size:0.7rem; font-family:monospace;">
                                            ID: @machine.MachineFingerprint[..Math.Min(16, machine.MachineFingerprint.Length)]…
                                        </div>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    @if (_confirmDeactivateId == machine.MachineId)
                                    {
                                        <span class="text-danger small me-1">Deactivate?</span>
                                        <button class="btn btn-danger btn-sm" @onclick="() => ConfirmDeactivate(machine.MachineId)">
                                            Yes
                                        </button>
                                        <button class="btn btn-outline-secondary btn-sm" @onclick="CancelDeactivate">
                                            No
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-danger btn-sm" @onclick="() => RequestDeactivate(machine.MachineId)">
                                            <i class="bi bi-x-circle me-1"></i>Deactivate
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-laptop fs-2 d-block mb-2"></i>
                        No machines activated yet. Open UtilityMenu in Excel to activate this device.
                    </div>
                }
            </div>
        </div>

        <!-- Help -->
        <div class="card border-0 shadow-sm bg-light">
            <div class="card-body">
                <h6 class="fw-semibold mb-2"><i class="bi bi-info-circle me-2 text-primary"></i>How device activation works</h6>
                <ul class="mb-0 text-muted small">
                    <li>Each licence allows up to <strong>@_licence.MaxActivations devices</strong> to be activated simultaneously.</li>
                    <li>A device is activated automatically the first time you use UtilityMenu on that machine.</li>
                    <li>Deactivating a device frees up a slot so you can activate a different machine.</li>
                    <li>Your licence key can be found on the <a href="/dashboard/licence">Licence</a> page.</li>
                </ul>
            </div>
        </div>
    }
}

@code {
    private Data.Models.User? _user;
    private Data.Models.Licence? _licence;
    private List<Data.Models.Machine> _machines = new();
    private Guid? _confirmDeactivateId;
    private bool _loading = true;
    private string? _message;
    private string _messageType = "info";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            var identityUser = await UserManager.GetUserAsync(authState.User);
            if (identityUser is null) { Nav.NavigateTo("/account/login"); return; }

            _user = await UserService.GetByIdentityIdAsync(identityUser.Id);
            if (_user is null) { Nav.NavigateTo("/dashboard"); return; }

            _licence = await LicenceService.GetActiveLicenceAsync(_user.UserId);
            if (_licence is not null)
                _machines = await LicenceService.GetActiveMachinesAsync(_licence.LicenceId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load devices page");
            _message = "Failed to load devices.";
            _messageType = "danger";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void RequestDeactivate(Guid machineId)
    {
        _confirmDeactivateId = machineId;
    }

    private void CancelDeactivate()
    {
        _confirmDeactivateId = null;
    }

    private async Task ConfirmDeactivate(Guid machineId)
    {
        try
        {
            await LicenceService.DeactivateMachineAsync(machineId);
            _machines = await LicenceService.GetActiveMachinesAsync(_licence!.LicenceId);
            _message = "Device deactivated successfully.";
            _messageType = "success";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to deactivate machine {MachineId}", machineId);
            _message = "Failed to deactivate device. Please try again.";
            _messageType = "danger";
        }
        finally
        {
            _confirmDeactivateId = null;
            StateHasChanged();
        }
    }
}
