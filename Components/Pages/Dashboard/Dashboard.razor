@page "/dashboard"
@rendermode InteractiveServer
@layout DashboardLayout
@attribute [Authorize]
@inject IUtilityMenuApiClient Api
@inject NavigationManager Nav
@inject ILogger<Dashboard> Logger

<PageTitle>Overview — UtilityMenu Dashboard</PageTitle>

@if (_loading)
{
    <LoadingSpinner Message="Loading your dashboard..." />
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Welcome back@(!string.IsNullOrWhiteSpace(_dashboard?.Profile.DisplayName) ? $", {_dashboard.Profile.DisplayName}" : "")!</h2>
            <p class="text-muted mb-0">@_dashboard?.Profile.Email</p>
        </div>
        @if (!string.IsNullOrWhiteSpace(_dashboard?.LatestVersion))
        {
            <a href="/download" class="btn btn-primary">
                <i class="bi bi-download me-2"></i>Download v@_dashboard.LatestVersion
            </a>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <AlertBanner Message="@_message" Type="@_messageType" />
    }

    <div class="row g-4 mb-4">
        <div class="col-sm-6 col-xl-3">
            <a href="/dashboard/licence" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 stat-card">
                    <div class="card-body d-flex flex-column gap-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted small fw-semibold text-uppercase">Licence</span>
                            <i class="bi bi-key fs-5 text-primary"></i>
                        </div>
                        @if (_dashboard?.ActiveLicence is not null)
                        {
                            <div class="fs-5 fw-bold text-dark">@_dashboard.ActiveLicence.LicenceType.ToUpperInvariant()</div>
                            <span class="badge @(_dashboard.ActiveLicence.IsActive ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger") align-self-start">
                                @(_dashboard.ActiveLicence.IsActive ? "Active" : "Inactive")
                            </span>
                        }
                        else
                        {
                            <div class="fs-5 fw-bold text-dark">Free</div>
                            <span class="badge bg-secondary-subtle text-secondary align-self-start">No licence</span>
                        }
                    </div>
                </div>
            </a>
        </div>

        <div class="col-sm-6 col-xl-3">
            <a href="/dashboard/billing" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 stat-card">
                    <div class="card-body d-flex flex-column gap-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted small fw-semibold text-uppercase">Subscription</span>
                            <i class="bi bi-credit-card fs-5 text-primary"></i>
                        </div>
                        @if (_dashboard?.Subscription is not null)
                        {
                            <div class="fs-5 fw-bold text-dark">@_dashboard.Subscription.PlanType.ToUpperInvariant()</div>
                            <span class="badge @GetStatusBadgeSubtle(_dashboard.Subscription.Status) align-self-start">@_dashboard.Subscription.Status</span>
                        }
                        else
                        {
                            <div class="fs-5 fw-bold text-dark">—</div>
                            <span class="badge bg-secondary-subtle text-secondary align-self-start">No plan</span>
                        }
                    </div>
                </div>
            </a>
        </div>

        <div class="col-sm-6 col-xl-3">
            <a href="/dashboard/devices" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 stat-card">
                    <div class="card-body d-flex flex-column gap-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted small fw-semibold text-uppercase">Devices</span>
                            <i class="bi bi-laptop fs-5 text-primary"></i>
                        </div>
                        <div class="fs-5 fw-bold text-dark">
                            @(_dashboard?.ActiveLicence?.Machines.Count ?? 0) <span class="text-muted fw-normal fs-6">/ @(_dashboard?.ActiveLicence?.MaxActivations ?? 2)</span>
                        </div>
                        <span class="text-muted small">activated machines</span>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-sm-6 col-xl-3">
            <a href="/dashboard/licence" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 stat-card">
                    <div class="card-body d-flex flex-column gap-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted small fw-semibold text-uppercase">Modules</span>
                            <i class="bi bi-puzzle fs-5 text-primary"></i>
                        </div>
                        <div class="fs-5 fw-bold text-dark">@(_dashboard?.ActiveLicence?.GrantedModules.Count ?? 0)</div>
                        <span class="text-muted small">unlocked modules</span>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-transparent border-0 fw-semibold">
                    <i class="bi bi-lightning me-2 text-primary"></i>Quick Actions
                </div>
                <div class="card-body d-flex flex-column gap-2">
                    <a href="/dashboard/licence" class="btn btn-outline-primary btn-sm text-start">
                        <i class="bi bi-key me-2"></i>View licence key &amp; modules
                    </a>
                    <a href="/dashboard/billing" class="btn btn-outline-primary btn-sm text-start">
                        <i class="bi bi-credit-card me-2"></i>Manage billing &amp; subscription
                    </a>
                    <a href="/dashboard/devices" class="btn btn-outline-primary btn-sm text-start">
                        <i class="bi bi-laptop me-2"></i>Manage activated devices
                    </a>
                    <a href="/dashboard/settings" class="btn btn-outline-primary btn-sm text-start">
                        <i class="bi bi-gear me-2"></i>Update profile &amp; API token
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-transparent border-0 fw-semibold">
                    <i class="bi bi-book me-2 text-primary"></i>Get Started
                </div>
                <div class="card-body d-flex flex-column gap-2">
                    @if (!string.IsNullOrWhiteSpace(_dashboard?.LatestVersion))
                    {
                        <a href="/download" class="btn btn-outline-secondary btn-sm text-start">
                            <i class="bi bi-download me-2"></i>Download add-in v@_dashboard.LatestVersion
                        </a>
                    }
                    <a href="/docs" class="btn btn-outline-secondary btn-sm text-start">
                        <i class="bi bi-file-earmark-text me-2"></i>Read the documentation
                    </a>
                    @if (_dashboard?.ActiveLicence is null)
                    {
                        <a href="/pricing" class="btn btn-primary btn-sm text-start">
                            <i class="bi bi-arrow-up-circle me-2"></i>Upgrade to Pro
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
}

<style>
    .stat-card { transition: box-shadow 0.15s, transform 0.15s; cursor: pointer; }
    .stat-card:hover { box-shadow: 0 .5rem 1rem rgba(0,0,0,.1) !important; transform: translateY(-2px); }
</style>

@code {
    private DashboardSummaryDto? _dashboard;
    private bool _loading = true;
    private string? _message;
    private string _messageType = "info";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var result = await Api.GetDashboardAsync();
        if (result.IsSuccess)
        {
            _dashboard = result.Value;
        }
        else
        {
            Logger.LogWarning("Dashboard load failed: {Code} {Message}", result.ErrorCode, result.ErrorMessage);
            _message = "Failed to load dashboard data.";
            _messageType = "danger";
        }
        _loading = false;
        StateHasChanged();
    }

    private static string GetStatusBadgeSubtle(string status) => status switch
    {
        "active"       => "bg-success-subtle text-success",
        "trialing"     => "bg-info-subtle text-info",
        "past_due"     => "bg-warning-subtle text-warning",
        "canceled"     => "bg-danger-subtle text-danger",
        "grace_period" => "bg-warning-subtle text-warning",
        _              => "bg-secondary-subtle text-secondary"
    };
}
