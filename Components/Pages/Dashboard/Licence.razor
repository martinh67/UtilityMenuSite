@page "/dashboard/licence"
@rendermode InteractiveServer
@layout DashboardLayout
@attribute [Authorize]
@using Microsoft.AspNetCore.Identity
@inject AuthenticationStateProvider AuthProvider
@inject UserManager<Data.Models.ApplicationUser> UserManager
@inject IUserService UserService
@inject ILicenceService LicenceService
@inject NavigationManager Nav
@inject ILogger<Licence> Logger

<PageTitle>Licence — UtilityMenu Dashboard</PageTitle>

@if (_loading)
{
    <LoadingSpinner Message="Loading licence details..." />
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Licence</h2>
            <p class="text-muted mb-0">Your licence key and module entitlements</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <AlertBanner Message="@_message" Type="@_messageType" />
    }

    @if (_licence is not null)
    {
        <!-- Licence Key Card -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent border-0 fw-semibold">
                <i class="bi bi-key me-2 text-primary"></i>Licence Key
            </div>
            <div class="card-body">
                <div class="row g-3 mb-3">
                    <div class="col-sm-6 col-md-4">
                        <div class="text-muted small mb-1">Status</div>
                        <span class="badge @(_licence.IsActive ? "bg-success" : "bg-danger") fs-6">
                            @(_licence.IsActive ? "Active" : "Inactive")
                        </span>
                    </div>
                    <div class="col-sm-6 col-md-4">
                        <div class="text-muted small mb-1">Licence Type</div>
                        <span class="fw-semibold">@_licence.LicenceType.ToUpperInvariant()</span>
                    </div>
                    @if (_licence.ExpiresAt.HasValue)
                    {
                        <div class="col-sm-6 col-md-4">
                            <div class="text-muted small mb-1">Expires</div>
                            <span class="fw-semibold @(_licence.ExpiresAt.Value < DateTime.UtcNow ? "text-danger" : "")">
                                @_licence.ExpiresAt.Value.ToString("MMMM d, yyyy")
                            </span>
                        </div>
                    }
                </div>
                <div class="mb-2 text-muted small">Use this key in the UtilityMenu add-in settings to activate your licence.</div>
                <LicenceKeyDisplay LicenceKey="@_licence.LicenceKey" />
            </div>
        </div>

        <!-- Module Entitlements -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent border-0 fw-semibold">
                <i class="bi bi-puzzle me-2 text-primary"></i>Module Entitlements
                <span class="badge bg-secondary ms-2">@_licence.LicenceModules.Count modules</span>
            </div>
            <div class="card-body">
                @if (_licence.LicenceModules.Any())
                {
                    <div class="row g-3">
                        @foreach (var lm in _licence.LicenceModules.OrderBy(m => m.Module?.Tier).ThenBy(m => m.Module?.SortOrder))
                        {
                            <div class="col-sm-6 col-lg-4">
                                <div class="d-flex align-items-start gap-3 p-3 bg-light rounded">
                                    <div class="text-success mt-1">
                                        <i class="bi bi-check-circle-fill fs-5"></i>
                                    </div>
                                    <div>
                                        <div class="fw-semibold small">@lm.Module?.DisplayName</div>
                                        <div class="text-muted" style="font-size:0.75rem;">
                                            @lm.Module?.Tier tier
                                            @if (lm.ExpiresAt.HasValue)
                                            {
                                                <span> · expires @lm.ExpiresAt.Value.ToString("MMM d, yyyy")</span>
                                            }
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(lm.Module?.Description))
                                        {
                                            <div class="text-muted mt-1" style="font-size:0.75rem;">@lm.Module.Description</div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">No modules are currently assigned to this licence.</p>
                }
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm text-center py-5">
            <div class="card-body">
                <i class="bi bi-key text-muted" style="font-size:3rem;"></i>
                <h5 class="mt-3 fw-semibold">No active licence</h5>
                <p class="text-muted">You don't have an active licence yet. Upgrade to Pro to unlock all features.</p>
                <a href="/pricing" class="btn btn-primary">
                    <i class="bi bi-arrow-up-circle me-2"></i>Upgrade to Pro
                </a>
            </div>
        </div>
    }
}

@code {
    private Data.Models.User? _user;
    private Data.Models.Licence? _licence;
    private bool _loading = true;
    private string? _message;
    private string _messageType = "info";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            var identityUser = await UserManager.GetUserAsync(authState.User);
            if (identityUser is null) { Nav.NavigateTo("/account/login"); return; }

            _user = await UserService.GetByIdentityIdAsync(identityUser.Id);
            if (_user is null) { Nav.NavigateTo("/dashboard"); return; }

            var userWithLicence = await UserService.GetWithLicenceAsync(_user.UserId);
            _licence = userWithLicence?.Licences?.FirstOrDefault(l => l.IsActive);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load licence page");
            _message = "Failed to load licence details.";
            _messageType = "danger";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }
}
