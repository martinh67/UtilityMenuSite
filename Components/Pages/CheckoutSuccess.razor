@page "/checkout/success"
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject IUtilityMenuApiClient Api
@inject ILogger<CheckoutSuccess> Logger

<PageTitle>Payment Successful — UtilityMenu</PageTitle>

<div class="container py-6">
    <div class="row justify-content-center">
        <div class="col-md-7 text-center">
            @if (_loading)
            {
                <LoadingSpinner Message="Confirming your payment..." />
            }
            else if (!string.IsNullOrWhiteSpace(_licenceKey))
            {
                <div class="mb-4">
                    <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex p-4 mb-3">
                        <i class="bi bi-check-circle-fill text-success display-4"></i>
                    </div>
                    <h1 class="fw-bold text-success">Payment Successful!</h1>
                    <p class="lead text-muted">Your Pro licence has been activated. Here is your licence key:</p>
                </div>

                <div class="card border-0 shadow-sm p-4 mb-4">
                    <LicenceKeyDisplay LicenceKey="@_licenceKey" />
                    <p class="text-muted small mt-3 mb-0">Save this key — you'll need it to activate UtilityMenu on each machine.</p>
                </div>

                <div class="d-flex gap-3 justify-content-center">
                    <a href="/download" class="btn btn-primary btn-lg">
                        <i class="bi bi-download me-2"></i>Download UtilityMenu
                    </a>
                    <a href="/dashboard" class="btn btn-outline-primary btn-lg">View Dashboard</a>
                </div>
            }
            else if (_timedOut)
            {
                <div class="alert alert-warning">
                    <h4 class="alert-heading">Still Processing</h4>
                    <p>Your payment was received but the licence is still being set up. Your key will appear in your <a href="/dashboard">dashboard</a> shortly. If it does not appear within 5 minutes, please <a href="/contact">contact support</a>.</p>
                </div>
                <a href="/dashboard" class="btn btn-primary mt-2">Go to Dashboard</a>
            }
            else if (!string.IsNullOrWhiteSpace(_error))
            {
                <AlertBanner Message="@_error" Type="danger" />
                <a href="/contact" class="btn btn-outline-danger mt-3">Contact Support</a>
            }
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "session_id")]
    public string? SessionId { get; set; }

    private bool _loading = true;
    private bool _timedOut;
    private string? _licenceKey;
    private string? _error;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (string.IsNullOrWhiteSpace(SessionId))
        {
            _loading = false;
            _error = "No session ID provided.";
            StateHasChanged();
            return;
        }
        await PollForLicenceAsync();
    }

    private async Task PollForLicenceAsync()
    {
        var timeout = DateTime.UtcNow.AddSeconds(60);
        while (DateTime.UtcNow < timeout)
        {
            var result = await Api.GetCheckoutStatusAsync(SessionId!);
            if (result.IsSuccess && result.Value is not null)
            {
                if (result.Value.Status == "complete" && !string.IsNullOrWhiteSpace(result.Value.LicenceKey))
                {
                    _licenceKey = result.Value.LicenceKey;
                    _loading = false;
                    StateHasChanged();
                    return;
                }
                if (result.Value.Status is "expired")
                {
                    _error = "Payment was not completed. Please try again.";
                    _loading = false;
                    StateHasChanged();
                    return;
                }
            }
            else
            {
                Logger.LogWarning("Checkout status poll failed: {Code} {Message}", result.ErrorCode, result.ErrorMessage);
            }
            await Task.Delay(3000);
        }

        _timedOut = true;
        _loading = false;
        StateHasChanged();
    }
}
