@page "/account/login"
@layout AuthLayout
@inject IUtilityMenuApiClient Api
@inject IAuthCookieIssuer AuthIssuer
@inject ILogger<Login> Logger

<PageTitle>Sign In — UtilityMenu</PageTitle>

<h4 class="fw-bold mb-1">Welcome back</h4>
<p class="text-muted small mb-4">Don't have an account? <a href="/account/register" data-enhance-nav="false">Create one</a></p>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <AlertBanner Message="@_errorMessage" Type="danger" />
}

<EditForm Model="_model" OnValidSubmit="HandleLogin" method="post" FormName="LoginForm" data-enhance="false">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label class="form-label small fw-semibold">Email Address</label>
        <InputText @bind-Value="_model.Email" type="email" class="form-control" placeholder="you@example.com" />
        <ValidationMessage For="() => _model.Email" class="text-danger small" />
    </div>

    <div class="mb-3">
        <label class="form-label small fw-semibold d-flex justify-content-between">
            Password
            <a href="/account/forgot-password" class="text-decoration-none small">Forgot password?</a>
        </label>
        <InputText @bind-Value="_model.Password" type="password" class="form-control" />
        <ValidationMessage For="() => _model.Password" class="text-danger small" />
    </div>

    <div class="mb-4">
        <div class="form-check">
            <InputCheckbox @bind-Value="_model.RememberMe" class="form-check-input" id="remember" />
            <label class="form-check-label small" for="remember">Remember me for 30 days</label>
        </div>
    </div>

    <button type="submit" class="btn btn-primary w-100">
        Sign In
    </button>
</EditForm>

@code {
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromForm]
    private LoginModel _model { get; set; } = default!;

    protected override void OnInitialized() => _model ??= new();

    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? _errorMessage;

    private async Task HandleLogin()
    {
        var result = await Api.LoginAsync(new LoginRequest(_model.Email!, _model.Password));

        if (result.IsSuccess && result.Value is not null)
        {
            await AuthIssuer.IssueAsync(HttpContext!, result.Value, persistent: _model.RememberMe);
            Logger.LogInformation("User {Email} signed in successfully via API", _model.Email);

            // Use Response.Redirect instead of NavigateTo so Blazor Enhanced Navigation
            // cannot intercept the 302 — the browser performs a full GET, the auth
            // cookie is sent, SSR re-renders with claims populated, and a fresh
            // antiforgery token is issued for the authenticated session.
            var destination = ReturnUrl is { Length: > 0 } r && r.StartsWith('/') && !r.StartsWith("//")
                ? r : "/dashboard";
            HttpContext!.Response.Redirect(destination);
            return;
        }

        _errorMessage = result.ErrorCode switch
        {
            "invalid_credentials" => "Invalid email or password.",
            "locked_out"          => "Your account has been locked due to too many failed attempts. Try again in 15 minutes.",
            "email_not_confirmed" => "Please confirm your email address before signing in.",
            "network_error"       => "Could not reach the server. Please try again.",
            _                     => result.ErrorMessage ?? "Sign-in failed. Please try again."
        };
        Logger.LogWarning("Login failed for {Email}: {Code} {Message}", _model.Email, result.ErrorCode, result.ErrorMessage);
    }

    private class LoginModel
    {
        [System.ComponentModel.DataAnnotations.Required, System.ComponentModel.DataAnnotations.EmailAddress]
        public string? Email { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        public string Password { get; set; } = string.Empty;

        public bool RememberMe { get; set; } = true;
    }
}
