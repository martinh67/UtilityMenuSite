@page "/account/reset-password"
@rendermode InteractiveServer
@layout AuthLayout
@inject IUtilityMenuApiClient Api
@inject NavigationManager Nav

<PageTitle>Reset Password — UtilityMenu</PageTitle>

<h4 class="fw-bold mb-1">Set new password</h4>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <AlertBanner Message="@_errorMessage" Type="danger" />
}

<EditForm Model="_model" OnValidSubmit="HandleReset">
    <DataAnnotationsValidator />
    <div class="mb-3">
        <label class="form-label small fw-semibold">New Password</label>
        <InputText @bind-Value="_model.Password" type="password" class="form-control" />
        <ValidationMessage For="() => _model.Password" class="text-danger small" />
    </div>
    <div class="mb-4">
        <label class="form-label small fw-semibold">Confirm Password</label>
        <InputText @bind-Value="_model.ConfirmPassword" type="password" class="form-control" />
        <ValidationMessage For="() => _model.ConfirmPassword" class="text-danger small" />
    </div>
    <button type="submit" class="btn btn-primary w-100" disabled="@_submitting">
        @if (_submitting) { <span class="spinner-border spinner-border-sm me-2"></span> }
        Reset Password
    </button>
</EditForm>

@code {
    [SupplyParameterFromQuery] public string? Email { get; set; }
    [SupplyParameterFromQuery] public string? Token { get; set; }

    private readonly ResetModel _model = new();
    private string? _errorMessage;
    private bool _submitting;

    private async Task HandleReset()
    {
        _submitting = true;
        if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Token))
        {
            _errorMessage = "Invalid reset link.";
            _submitting = false;
            return;
        }

        var result = await Api.ResetPasswordAsync(new ResetPasswordRequest(Email, Token, _model.Password));
        if (result.IsSuccess)
            Nav.NavigateTo("/account/login?reset=true");
        else
            _errorMessage = result.ErrorCode switch
            {
                "invalid_request" => "Invalid or expired reset link.",
                "reset_failed"    => result.ErrorMessage ?? "Reset failed. Please try again.",
                "network_error"   => "Could not reach the server. Please try again.",
                _                 => result.ErrorMessage ?? "Reset failed. Please try again."
            };

        _submitting = false;
    }

    private class ResetModel
    {
        [System.ComponentModel.DataAnnotations.Required, System.ComponentModel.DataAnnotations.MinLength(8)]
        public string Password { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Compare(nameof(Password), ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
