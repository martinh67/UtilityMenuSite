<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>UtilityMenuSite</RootNamespace>
    <UserSecretsId>utilitymenusite-dev-secrets</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <!-- Phase 3 BFF: Site is now a thin Blazor UI that calls UtilityMenuAPI
         for all data + auth. EF Core, Identity-EF, and Stripe.net are gone —
         the API owns the database, JWT issuance, and Stripe SDK calls.
         Cookie auth is built into ASP.NET Core (no separate package needed). -->
    <PackageReference Include="Markdig" Version="0.37.0" />
    <PackageReference Include="Microsoft.ApplicationInsights.AspNetCore" Version="2.22.0" />

    <!-- Data Protection persistence (Azure Blob). Mirrors API package set so
         keys generated by either app share the same persistence model.
         Without persistent keys, every redeploy invalidates auth cookies,
         silently logging out every user. -->
    <PackageReference Include="Azure.Identity" Version="1.14.2" />
    <PackageReference Include="Azure.Extensions.AspNetCore.DataProtection.Blobs" Version="1.3.4" />
  </ItemGroup>

</Project>
